{
  "name": "web-push",
  "version": "3.6.7",
  "description": "Web Push library for Node.js",
  "keywords": [
    "notifications",
    "push",
    "push notifications",
    "web push"
  ],
  "homepage": "https://github.com/web-push-libs/web-push#readme",
