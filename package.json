    "minimist": "^1.2.5"
  },
  "devDependencies": {
    "chromedriver": "123.0.3",
    "del": "6.0.0",
    "geckodriver": "4.3.0",
    "mkdirp": "3.0.1",
    "mocha": "10.4.0",
    "nyc": "15.1.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.21.1",
    "portfinder": "1.0.32",
    "selenium-assistant": "5.4.0",
    "sinon": "17.0.1",
    "tsdown": "^0.21.9"
  },
  "engines": {
    "node": ">=22"
  }
