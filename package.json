  "repository": {
    "type": "git",
    "url": "git+https://github.com/web-push-libs/web-push.git"
  },
  "files": [
    "dist"
  ],
  "main": "dist/index.mjs",
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "tsdown",
    "download-browser": "node ./test/helpers/download-test-browsers.js",
