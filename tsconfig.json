{
  "compilerOptions": {
    "target": "esnext",

    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,

    "erasableSyntaxOnly": true,
    "allowImportingTsExtensions": true,

    "forceConsistentCasingInFileNames": true,

    "strict": true,

    "skipLibCheck": true
  },
  "typedocOptions": {
    "entryPoints": ["src/index.ts"],
    "excludePrivate": true,
    "out": "docs"
  }
}
